{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.js) node --check \"$f\";; esac; }",
            "timeout": 10,
            "statusMessage": "JS-Syntax prüfen..."
          }
        ]
      }
    ]
  }
}
